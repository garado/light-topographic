{
  "expo": {
    "name": "Topographic",
    "slug": "topographic",
    "version": "1.0.0-rc.1",
    "orientation": "portrait",
    "scheme": "topographic",
    "icon": "./assets/images/icon.png",
    "android": {
      "backgroundColor": "#000000",
      "package": "com.garado.topographic",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/PublicSans-Regular.ttf"
          ]
        }
      ],
      "./plugins/withAndroidConfigChanges",
      "./plugins/withAndroidTheme"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "582d6a9f-3f1c-4e40-b52d-df753f0a7268"
      }
    },
    "owner": "agarado",
    "ios": {
      "bundleIdentifier": "com.garado.topographic"
    }
  }
}
